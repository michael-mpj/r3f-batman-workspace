{
  "name": "@michael-mpj/r3f-batman",
  "version": "2.0.0",
  "description": "R3F Batman Workspace - Advanced React Three Fiber development environment",
  "license": "MIT",
  "type": "module",
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "packages/*",
    "projects/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=projects/R3f-StarterKit",
    "build": "npm run build:production",
    "build:starterkit": "npm run build --workspace=projects/R3f-StarterKit",
    "build:cyber-forge": "npm run build --workspace=apps/cyber-forge",
    "build:production": "npm run build:starterkit && npm run build:cyber-forge",
    "deploy:starterkit:production": "cd projects/R3f-StarterKit && vercel --prod",
    "deploy:cyber-forge:production": "cd apps/cyber-forge && vercel --prod",
    "deploy:starterkit:preview": "cd projects/R3f-StarterKit && vercel",
    "deploy:cyber-forge:preview": "cd apps/cyber-forge && vercel",
    "deploy:production": "npm run deploy:starterkit:production && npm run deploy:cyber-forge:production",
    "deploy:preview": "npm run deploy:starterkit:preview && npm run deploy:cyber-forge:preview",
    "preview:starterkit": "npm run preview --workspace=projects/R3f-StarterKit",
    "preview:cyber-forge": "npm run preview --workspace=apps/cyber-forge",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "format": "prettier --write .",
    "check-compatibility": "node scripts/check-compatibility.mjs",
    "workspace:create": "node scripts/create-workspace.mjs",
    "batman": "node scripts/batman.mjs",
    "batman:enhanced": "node scripts/batman-enhanced.mjs",
    "batman:vscode": "node scripts/batman-vscode.mjs",
    "batman:auto": "node scripts/batman-auto-close.mjs",
    "batman:ultimate": "node scripts/batman-ultimate.mjs",
    "cleanup:deployments": "node cleanup-github-deployments.cjs && node cleanup-vercel-deployments.cjs",
    "prepare": "husky",
    "auto-merge": "node scripts/auto-merge.mjs",
    "extensions:install": "node scripts/batman-install-extensions.mjs",
    "extensions:list": "code --list-extensions",
    "commit:format": "node scripts/batman-commit-auto.mjs",
    "commit:test": "echo 'Testing Batman commit formatter...' && node scripts/batman-commit-auto.mjs",
    "security:audit": "npm audit --audit-level=moderate",
    "security:audit-fix": "npm audit fix",
    "security:check": "npm audit --audit-level=high",
    "security:outdated": "npm outdated",
    "security:licenses": "npx license-checker --summary",
    "security:full-check": "node scripts/security-check.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/xr": "^6.6.30",
    "json-schema": "^0.4.0",
    "leva": "^0.10.0",
    "node-fetch": "^2.7.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.184.0",
    "tsx-to-jsx": "^0.0.4",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.28.3",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.26.2",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^10.0.1",
    "@react-three/eslint-plugin": "^0.1.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.1.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/browser": "^3.2.6",
    "@vitest/ui": "^3.2.6",
    "babel-jest": "^30.1.2",
    "concurrently": "^9.2.3",
    "deep-equal": "^2.2.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.1.1",
    "jest-environment-jsdom": "^30.1.2",
    "lint-staged": "^16.1.6",
    "prettier": "^3.8.4",
    "turbo": "^2.10.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.14",
    "vitest": "^3.2.6"
  },
  "lint-staged": {
    "*.{js,jsx,mjs}": [
      "eslint --fix"
    ]
  },
  "engines": {
    "node": "^24.0.0",
    "npm": ">=10.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/michael-mpj/r3f-batman-workspace.git"
  },
  "homepage": "https://github.com/michael-mpj/r3f-batman-workspace#readme",
  "bugs": {
    "url": "https://github.com/michael-mpj/r3f-batman-workspace/issues"
  },
  "urls": {
    "github": "https://github.com/michael-mpj/r3f-batman-workspace",
    "vercel": {
      "r3f-starterkit": "https://r3f-starterkit.vercel.app",
      "cyber-forge": "https://cyber-forge.vercel.app"
    }
  }
}