{
  "name": "@r3f-workspace/r3f-components",
  "version": "1.0.0",
  "description": "Advanced React Three Fiber components for 3D applications",
  "type": "module",
  "main": "src/index.js",
  "module": "src/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/generate-landing-data.mjs && vite build && cp public/index.html dist/index.html",
    "dev": "vite build --watch",
    "lint": "eslint src --ext js,jsx,mjs",
    "lint:fix": "eslint src --ext js,jsx,mjs --fix",
    "test": "vitest",
    "test:ci": "vitest run",
    "clean": "rimraf dist",
    "format": "prettier --write ."
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "@react-three/fiber": "^9.6.1",
    "three": "^0.184.0"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@r3f-workspace/utils": "file:../utils"
  },
  "devDependencies": {
    "vite": "^8.1.0",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.5.0",
    "vitest": "^3.2.6",
    "@testing-library/react": "^16.3.0",
    "rimraf": "^6.1.3",
    "prettier": "^3.8.4"
  },
  "keywords": [
    "react",
    "three.js",
    "3d",
    "components",
    "r3f",
    "react-three-fiber"
  ]
}